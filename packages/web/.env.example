# =============================================================================
# packages/web — environment variables
# =============================================================================

# ---- Legacy local Postgres (Prisma) -----------------------------------------
# Used as a fallback when Supabase env vars are not set.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/restaurant_reservations?schema=public"

# ---- Optional: standalone Express+Socket.io API ------------------------------
# When set, the browser hits this base URL instead of /api/*.
# NEXT_PUBLIC_API_BASE_URL="http://127.0.0.1:4000"

# ---- Supabase (production backend) ------------------------------------------
# Find these in your Supabase project: Settings → API
# When set, both the browser and server-side API routes prefer Supabase
# (RPC `create_reservation`, `get_available_tables`, `get_day_slots`, etc.).

NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Demo restaurant the public marketing UI books against. Defaults to the
# well-known UUID seeded in supabase/migrations/008_seed.sql.
NEXT_PUBLIC_DEMO_RESTAURANT_ID="00000000-0000-0000-0000-00000000d0a1"

# Server-only. NEVER expose to the browser. Only required for cron / admin
# tasks that need to bypass RLS. Public booking does NOT need this.
# SUPABASE_SERVICE_ROLE_KEY=""
